{
  "name": "smart-review",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Review plugin workspace.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @smart-review/obsidian-plugin dev",
