{
  "name": "smart-review",
  "version": "0.3.1",
  "private": true,
  "description": "Smart Review plugin workspace.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:plugin": "pnpm --filter @smart-review/shared build && pnpm --filter @smart-review/obsidian-plugin build",
    "dev": "pnpm --filter @smart-review/obsidian-plugin dev",
    "lint": "eslint apps/smart-review-plugin --max-warnings=0 && stylelint apps/smart-review-plugin/styles.css --max-warnings=0 && pnpm -r lint",
    "audit:review": "node scripts/audit-review-index.js",
    "analyze:history": "node scripts/analyze-review-history.js",
    "generate:ai-cards": "node scripts/generate-ai-review-cards.js",
    "release:plugin": "pnpm run sync:plugin-release && pnpm run build:plugin && node scripts/prepare-plugin-release.js",
    "sync:plugin-release": "node scripts/sync-plugin-release.js",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @smart-review/shared build && pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "stylelint": "^16.26.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
